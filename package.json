  },
  "dependencies": {
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "nanoid": "^5.1.11",
    "cors": "^2.8.5",
    "dotenv": "^17.2.6",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "react": "^19.2.6",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.1.1",
    "zod": "^4.4.3",
    "zundo": "^2.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "concurrently": "^9.1.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
